#!/bin/sh

label='#d79921'
value='#ebdbb2'

sanitize_utf8()
{
    iconv -f UTF-8 -t UTF-8 -c
}

escape_pango()
{
    sed \
        -e 's/&/\&amp;/g' \
        -e 's/</\&lt;/g' \
        -e 's/>/\&gt;/g'
}

window_id=$(
    xprop -root _NET_ACTIVE_WINDOW 2>/dev/null |
        awk '{ print $NF }'
)

[ -n "$window_id" ] || exit 0
[ "$window_id" != '0x0' ] || exit 0

title=$(
    xprop -id "$window_id" _NET_WM_NAME 2>/dev/null |
        sed -n 's/^_NET_WM_NAME([^)]*) = "\(.*\)"$/\1/p' |
        head -n 1 |
        sanitize_utf8
)

if [ -z "$title" ]; then
    title=$(
        xprop -id "$window_id" WM_NAME 2>/dev/null |
            sed -n 's/^WM_NAME([^)]*) = "\(.*\)"$/\1/p' |
            head -n 1 |
            sanitize_utf8
    )
fi

[ -n "$title" ] || exit 0

short_title=$(printf '%s' "$title" | cut -c 1-30)
escaped_title=$(printf '%s' "$title" | escape_pango)
escaped_short_title=$(printf '%s' "$short_title" | escape_pango)

printf '<span foreground="%s"></span> <span foreground="%s">%s</span>\n' \
    "$label" \
    "$value" \
    "$escaped_title"

printf '%s\n' "$escaped_short_title"
