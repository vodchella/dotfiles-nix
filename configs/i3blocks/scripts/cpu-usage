#!/bin/sh
label='#d79921'; normal='#ebdbb2'; warning='#fe8019'; critical='#fb4934'
read_cpu() { awk '/^cpu / { idle=$5+$6; total=0; for(i=2;i<=NF;i++) total+=$i; print total, idle; exit }' /proc/stat; }
set -- $(read_cpu); total_1=$1; idle_1=$2
sleep 0.2
set -- $(read_cpu); total_2=$1; idle_2=$2
total_delta=$((total_2-total_1)); idle_delta=$((idle_2-idle_1))
if [ "$total_delta" -gt 0 ]; then usage=$((100*(total_delta-idle_delta)/total_delta)); else usage=0; fi
color=$normal
if [ "$usage" -ge 80 ]; then color=$critical; elif [ "$usage" -ge 50 ]; then color=$warning; fi
printf '<span foreground="%s">’Æ╝</span> <span foreground="%s">%d%%</span>\n' "$label" "$color" "$usage"
