#!/bin/sh
label='#d79921'
value='#ebdbb2'
escape_pango() { printf '%s' "$1" | sed -e 's/&/\&amp;/g' -e 's/</\&lt;/g' -e 's/>/\&gt;/g'; }
window_id=$(xprop -root _NET_ACTIVE_WINDOW 2>/dev/null | awk '{ print $NF }')
[ -n "$window_id" ] || exit 0
[ "$window_id" != '0x0' ] || exit 0
title=$(xprop -id "$window_id" _NET_WM_NAME WM_NAME 2>/dev/null | sed -n -e 's/^_NET_WM_NAME([^)]*) = "\(.*\)"$/\1/p' -e 's/^WM_NAME([^)]*) = "\(.*\)"$/\1/p' | head -n 1)
[ -n "$title" ] || exit 0
title=$(escape_pango "$title")
printf '<span foreground="%s"></span> <span foreground="%s">%s</span>\n' "$label" "$value" "$title"
printf '%s\n' "$title" | cut -c 1-30
